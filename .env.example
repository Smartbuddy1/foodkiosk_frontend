# Shared
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Database and Redis
DATABASE_URL=postgresql://food:food@localhost:5432/food_kiosk?schema=public
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Receipt printer
PRINTER_ENABLED=false
PRINTER_INTERFACE=usb
PRINTER_VENDOR_ID=
PRINTER_PRODUCT_ID=
PRINTER_HOST=
PRINTER_PORT=9100

# Restaurant settings
RESTAURANT_NAME=Golden Burger Works
RESTAURANT_GST_NUMBER=29ABCDE1234F1Z5
DAILY_REVENUE_GOAL=1000
KIOSK_IDLE_TIMEOUT_SECONDS=60
CASH_PAYMENT_ENABLED=true

# Client
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
